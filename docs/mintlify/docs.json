{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Tax Engine",
  "description": "Open-source IRS Form 1040 tax engine. Runs locally. Works with Claude, ChatGPT, Gemini, and any AI platform.",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#18181B",
    "light": "#FFFFFF",
    "dark": "#09090B"
  },
  "css": ["/custom.css"],
  "modeToggle": {
    "default": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/filed-app/tax-engine"
      }
    ],
    "primary": {
      "type": "button",
      "label": "⭐ Star on GitHub",
      "href": "https://github.com/filed-app/tax-engine"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "introduction",
          "getting-started/install",
          "getting-started/quick-start"
        ]
      },
      {
        "group": "Use with AI",
        "pages": [
          "use-with-ai/overview",
          "use-with-ai/claude",
          "use-with-ai/chatgpt",
          "use-with-ai/gemini"
        ]
      },
      {
        "group": "CLI Reference",
        "pages": [
          "cli/overview",
          "cli/returns",
          "cli/forms",
          "cli/nodes"
        ]
      },
      {
        "group": "Input Nodes",
        "pages": [
          "input-nodes/overview",
          "input-nodes/income",
          "input-nodes/schedules",
          "input-nodes/deductions",
          "input-nodes/credits",
          "input-nodes/capital",
          "input-nodes/other"
        ]
      },
      {
        "group": "Architecture",
        "pages": [
          "architecture/how-it-works",
          "architecture/tax-node",
          "architecture/adding-a-node"
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/filed-app/tax-engine"
  },
  "llms": {
    "title": "Tax Engine",
    "description": "Open-source IRS Form 1040 tax engine. Runs locally. Works with Claude, ChatGPT, Gemini, and any AI platform."
  },
  "search": {
    "prompt": "Search the tax engine docs..."
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbsRating": true
  }
}
